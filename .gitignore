# Plugin build artefacts
plugin/target/
plugin/dependency-reduced-pom.xml

# Paper server install — entirely generated by `./agentcraft setup` (Paper jar,
# downloaded libraries, worlds, configs, crash reports, spark profiles). The
# only stateful bit, server/plugins/AgentCraft/rooms.yml, lives here too and is
# intentionally machine-local — a fresh clone re-runs setup.
server/

# Run-time logs, pid files, and Playwright MCP debug dumps
logs/
.pids/
.playwright-mcp/

# Headless Chrome user-data-dir for the Omo overlay — runtime state, not source.
.omo-overlay-chrome/

# Node
node_modules/
runtime/.env
runtime/dist/
runtime/secrets/
runtime/data/
face/.env
# Compiled Swift binary — built locally with face/capture/build.sh
face/capture/WindowCapture

# Never commit env backups/dumps — these have leaked real keys into history.
runtime/.env.bak
*.env.bak

# OS
.DS_Store

# Omo ADK agent service
omo-agent/.venv/
omo-agent/**/.env
omo-agent/**/__pycache__/
