# --- AgentCraft runtime configuration ---

# WebSocket port the Paper plugin connects to (loopback-only; not player-facing).
AGENTCRAFT_WS_PORT=8765
# Shared secret for the plugin<->runtime bridge. CHANGE THIS to a random value.
AGENTCRAFT_WS_TOKEN=change-me-shared-secret

# Access token the in-game client mod must present to reach the two PLAYER-FACING
# ports over the network: :8766 (Omo HUD/voice) and :8767 (team terminal).
# Leave BLANK for local-only play — the runtime trusts loopback. Before exposing
# the server to friends, set a long random value here AND bake the SAME value
# into the client mod (RuntimeHost DEFAULT_TOKEN, or launch with
# -Dagentcraft.token=… / AGENTCRAFT_TOKEN=…). While blank, remote clients are
# refused outright (fail-closed) so the agent PTYs never sit open on the internet.
OMO_CLIENT_TOKEN=

# --- omo business-data feed ---
# Base URL of the omo voice cofounder app. The runtime polls
# /omo/api/integrations/{stripe,meta,gmail}/summary every OMO_POLL_MS and
# paints the HQ map dashboard (room=hq-atrium) with the result. Snapshots
# persist to runtime/data/snapshots/ so displays never go blank.
OMO_BASE_URL=http://127.0.0.1:8080
OMO_POLL_MS=300000

# --- Hermes inference (OpenAI-compatible endpoint) ---
# Pick ONE of these blocks.

# A) Local nousresearch/hermes-agent install (recommended if you already have it
#    set up and logged into a provider — uses ITS configured model + skills +
#    learning loop. Each AgentCraft agent gets its own hermes-agent session.)
HERMES_BASE_URL=http://127.0.0.1:8642/v1
HERMES_API_KEY=hermes-agent
HERMES_MODEL=hermes-agent

# B) Hosted Hermes via OpenRouter / Together / Nous portal
# HERMES_BASE_URL=https://openrouter.ai/api/v1
# HERMES_API_KEY=sk-or-v1-replace-me
# HERMES_MODEL=nousresearch/hermes-4-405b

HERMES_MAX_TOKENS=2048
HERMES_TEMPERATURE=0.7

# Verbose runtime logging — set true to log every WS message, every hermes
# request/response, and every agent reasoning step into logs/runtime.log.
AGENTCRAFT_DEBUG=true

# --- Tool credentials (filled in per agent room) ---
# Gmail (per-agent tools): drop OAuth JSON in ./secrets/gmail.json
# Spotify: drop OAuth JSON in ./secrets/spotify.json
#   { "client_id": "...", "client_secret": "...", "refresh_token": "..." }
#   Required scopes: user-read-playback-state user-modify-playback-state user-read-currently-playing
#   Playback control needs Spotify Premium.

# --- Real business data integrations (optional) ---
# When set, the runtime polls these APIs DIRECTLY every OMO_POLL_MS and
# ships the numbers into the HQ hologram board. Without them, OmoClient
# falls back to fetching /omo/api/integrations/{stripe,meta,gmail}/summary
# from OMO_BASE_URL — both modes coexist.

# Stripe (restricted read-only key strongly recommended)
# Create at https://dashboard.stripe.com/apikeys → "Create restricted key"
# Permissions: read-only on Charges, Customers, Subscriptions, Balance,
# Disputes, Payouts, Events.
# STRIPE_SECRET_KEY=rk_live_...
# STRIPE_LIVE=1   # honored only as a label — not gating

# Meta Ads (Graph API v19.0)
# Long-lived token from https://developers.facebook.com/tools/explorer/
# Required permission: ads_read.
# META_ADS_ACCESS_TOKEN=
# META_ADS_ACCOUNT_ID=act_XXXXXXXXX
# (FB_ACCESS_TOKEN + FB_AD_ACCOUNT_ID are also accepted as aliases.)

# Gmail (Google OAuth)
# 1. GCP Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
#    of type "Web application". Authorized redirect URI = whatever matches
#    GOOGLE_OAUTH_REDIRECT_URI below.
# 2. Use Google's OAuth Playground (https://developers.google.com/oauthplayground/)
#    OR omo's /auth/google/start endpoint to get a refresh token. Scope:
#    https://www.googleapis.com/auth/gmail.readonly is enough for this
#    connector (we only read INBOX label + count IMPORTANT messages).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/google/callback
