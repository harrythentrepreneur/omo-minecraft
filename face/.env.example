# omo-mc face — environment.
#
# Drop this file at face/.env (not .env.example) and fill in GEMINI_API_KEY.
# Everything else has sensible defaults.

# Required — without this, the cylinder boots but voice fails at /session.
GEMINI_API_KEY=AIza...

# Optional — pick a different prebuilt Gemini Live voice.
# Common picks: Aoede (breathy), Leda (warm, default), Puck (bright).
# GEMINI_VOICE=Leda

# Optional — switch the model.
# GEMINI_MODEL=gemini-3.1-flash-live-preview

# Optional — default conversational language.
# GEMINI_LANGUAGE=en-US

# Optional — where the omo-mc runtime listens. Default matches ./agentcraft.
# AGENTCRAFT_RUNTIME_HTTP=http://127.0.0.1:8766

# Optional — port for the face itself. Default 8080 (matches omo, matches PRD).
# OMO_FACE_PORT=8080

# Optional — set to "false" to disable the headless Chrome that renders the
# in-game Omo overlay automatically. When disabled, the in-game HUD falls
# back to the bundled static face PNG (or stays blank) until you open
# http://localhost:8080/overlay in a browser manually. Leave unset (default
# "true") for the normal "Omo is always in the top-left" experience.
# OMO_HEADLESS_OVERLAY=true

# Optional — absolute path to a Chrome/Chromium binary. Only needed if the
# auto-detect can't find Chrome (e.g. portable install, non-standard path).
# OMO_CHROME_BINARY=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
